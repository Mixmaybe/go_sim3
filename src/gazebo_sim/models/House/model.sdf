<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="house">
    <static>true</static>

    <link name="link">
      <pose>0 0 1 1.5708 0 0</pose>

      <!-- House mesh -->
      <visual name="visual">
        <geometry>
          <mesh>
            <uri>model://house/meshes/model.glb</uri>
          </mesh>
        </geometry>
      </visual>

      <collision name="collision_mesh">
        <geometry>
          <mesh>
            <uri>model://house/meshes/model.glb</uri>
          </mesh>
        </geometry>
      </collision>

      <!-- FLOOR COLLISION (counter rotation)
      <collision name="floor_collision">
        <pose>0 0 0 -1.5708 0 0</pose>
        <geometry>
          <box>
            <size>10 10 0.1</size>
          </box>
        </geometry>
      </collision>
      
      <visual name="floor_visual">
        <pose>0 0 0 -1.5708 0 0</pose>
        <geometry>
          <box>
            <size>9 8 0.1</size>
          </box>
        </geometry>

        <material>
          <ambient>0.45 0.45 0.45 1</ambient>
          <diffuse>0.55 0.55 0.55 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>  -->

    </link>
  </model>
</sdf>
